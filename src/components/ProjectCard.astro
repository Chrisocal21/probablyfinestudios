---
interface ProjectTheme {
	gradient: string;
	accent: string;
	pattern?: string;
	patternSize?: string;
}

interface Props {
	title: string;
	description: string;
	tags: string[];
	liveUrl?: string;
	githubUrl?: string;
	wip?: boolean;
	theme?: ProjectTheme;
	collaborators?: Array<{ name: string; url: string }>;
}

const { title, description, tags, liveUrl, githubUrl, wip, theme, collaborators } = Astro.props;
---

<div class="bg-gray-900 rounded-xl overflow-hidden border border-gray-800 hover:border-white/20 transition duration-300 flex flex-col">
	<!-- Preview -->
	<div class="relative overflow-hidden" style={`background: ${theme?.gradient ?? 'linear-gradient(135deg, #312e81, #1e1b4b)'}`}>
		{theme?.pattern && (
			<div class="absolute inset-0" style={`background-image: ${theme.pattern}; background-size: ${theme.patternSize ?? 'auto'}`}></div>
		)}
		{liveUrl ? (
			<div class="relative m-3 rounded-lg overflow-hidden border border-white/10">
				<div class="flex items-center gap-2 px-3 py-1.5 bg-black/60 border-b border-white/10">
					<div class="flex gap-1">
						<div class="w-2 h-2 rounded-full bg-red-500/70"></div>
						<div class="w-2 h-2 rounded-full bg-yellow-500/70"></div>
						<div class="w-2 h-2 rounded-full bg-green-500/70"></div>
					</div>
					<div class="flex-1 mx-2 bg-white/10 rounded px-2 py-0.5 text-xs text-gray-400 truncate">
						{liveUrl.replace('https://', '')}
					</div>
				</div>
				<div class="aspect-video bg-gray-900">
					<img
						src={`https://s0.wordpress.com/mshots/v1/${encodeURIComponent(liveUrl)}?w=900&h=506`}
						alt={`${title} preview`}
						class="w-full h-full object-contain"
						loading="lazy"
					/>
				</div>
			</div>
		) : (
			<div class="aspect-video"></div>
		)}
	</div>

	<!-- Content -->
	<div class="p-5 flex flex-col flex-1 gap-3">
		<div>
			<div class="flex items-start justify-between gap-3 mb-1">
				<h3 class="text-xl font-bold text-white">{title}</h3>
				{wip && (
					<span class="text-[10px] font-medium tracking-widest uppercase px-2 py-0.5 rounded-full shrink-0 mt-1" style={`background: ${theme?.accent ?? '#fbbf24'}18; color: ${theme?.accent ?? '#fbbf24'}; border: 1px solid ${theme?.accent ?? '#fbbf24'}40`}>
						In Development
					</span>
				)}
			</div>
			<p class="text-gray-400 text-sm">{description}</p>
		</div>

		<div class="flex flex-wrap gap-1.5">
			{tags.map(tag => (
				<span class="bg-white/5 text-gray-300 px-2.5 py-0.5 rounded-full text-xs" style={`border: 1px solid ${theme?.accent ?? '#ffffff'}30`}>
					{tag}
				</span>
			))}
		</div>

		{collaborators && collaborators.length > 0 && (
			<p class="text-xs text-gray-500">
				<span class="uppercase tracking-widest mr-1">With:</span>
				{collaborators.map((collab, i) => (
					<Fragment>
						<a href={collab.url} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition underline">{collab.name}</a>
						{i < collaborators.length - 1 && ', '}
					</Fragment>
				))}
			</p>
		)}

		<div class="flex gap-2 mt-auto pt-1">
			{liveUrl && (
				<a
					href={liveUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="px-4 py-2 rounded-lg font-semibold text-sm transition hover:opacity-90"
					style={`background: ${theme?.accent ?? '#ffffff'}; color: #000`}
				>
					View Project
				</a>
			)}
			{githubUrl && (
				<a
					href={githubUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="border border-gray-700 text-gray-300 px-4 py-2 rounded-lg text-sm hover:bg-gray-800 transition"
				>
					View Code
				</a>
			)}
		</div>
	</div>
</div>

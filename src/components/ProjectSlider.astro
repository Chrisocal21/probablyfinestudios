---
import { projects } from '../data/projects';

interface Props {
	autoplay?: boolean;
}

const { autoplay = false } = Astro.props;
---

<div class="slider-container relative h-screen w-full overflow-hidden">
	
	<!-- Slider wrapper -->
	<div class="slider-wrapper relative h-full">
		<div class="slider flex h-full transition-transform duration-500 ease-out">
			<!-- PFS Hero Slide -->
			<div class="slide flex-shrink-0 w-full h-full relative" data-index="0">
				<!-- Background -->
				<div class="absolute inset-0" style="background: linear-gradient(135deg, #0a0a0f 0%, #0f0a1a 40%, #0a0f1a 100%)"></div>
				<!-- Pattern: fine diagonal grid -->
				<div class="absolute inset-0" style="background-image: linear-gradient(rgba(139,92,246,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(139,92,246,0.06) 1px, transparent 1px); background-size: 40px 40px"></div>
				<!-- Radial glow -->
				<div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 50% 50%, rgba(99,59,200,0.18) 0%, transparent 70%)"></div>
				<!-- Bottom fade -->
				<div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent"></div>

				<!-- Content -->
				<div class="relative h-full flex items-center justify-center px-4 sm:px-6 lg:px-8">
					<div class="max-w-4xl text-center">
						<!-- Wordmark -->
						<div class="w-16 h-1 mx-auto mb-8 rounded-full" style="background: linear-gradient(90deg, #8b5cf6, #6366f1)"></div>
						<h1 class="text-5xl md:text-7xl font-bold text-white mb-6 tracking-tight">
							Probably Fine <span style="background: linear-gradient(90deg, #8b5cf6, #6366f1, #60a5fa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text">Studios</span>
						</h1>
						<p class="text-xl md:text-2xl text-gray-300 mb-8 max-w-2xl mx-auto">
							One developer, a handful of good ideas, and AI doing the heavy lifting. Real products, shipped — photography tools, recipe apps, maps, dashboards, games. And honestly? They're probably fine.
						</p>
						<div class="flex gap-4 justify-center">
							<button
								id="pfs-view-work"
								class="group px-8 py-4 rounded-lg font-semibold transition duration-300 transform hover:scale-105"
								style="background: linear-gradient(90deg, #8b5cf6, #6366f1); color: #fff"
							>
								<span class="flex items-center gap-2">
									View Our Work
									<svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
									</svg>
								</span>
							</button>
							<a
								href="/team"
								class="px-8 py-4 rounded-lg font-semibold transition border text-white hover:bg-white/10"
								style="border-color: rgba(139,92,246,0.4)"
							>
								Meet the Team
							</a>
						</div>
					</div>
				</div>
			</div>
			{projects.map((project, index) => (
			<div class="slide flex-shrink-0 w-full h-full relative" data-index={index + 1}>
				<!-- Per-project themed background -->
				<div class="absolute inset-0 transition-all duration-500" style={`background: ${project.theme?.gradient ?? 'linear-gradient(135deg, #312e81, #1e1b4b, #000)'}`}></div>
				<!-- CSS pattern overlay -->
				{project.theme?.pattern && (
					<div
						class="absolute inset-0"
						style={`background-image: ${project.theme.pattern}; background-size: ${project.theme.patternSize ?? 'auto'}`}
					></div>
				)}
				<!-- Bottom fade for content legibility -->
				<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>
				
				<!-- Project content -->
				<div class="relative h-full flex items-center justify-center px-4 sm:px-6 lg:px-8 py-6">
					<div class="w-full max-w-3xl flex flex-col items-center text-center gap-2">

						<!-- Title block -->
						<div class="mb-1">
							<div class="w-8 h-1 mb-2 rounded-full mx-auto" style={`background: ${project.theme?.accent ?? '#818cf8'}`}></div>
							<h2 class="text-3xl md:text-4xl font-bold text-white mb-1">
								{project.title}
							</h2>
							{project.wip && (
								<span class="inline-block text-xs font-medium tracking-widest uppercase px-3 py-0.5 rounded-full" style={`background: ${project.theme?.accent ?? '#fbbf24'}18; color: ${project.theme?.accent ?? '#fbbf24'}; border: 1px solid ${project.theme?.accent ?? '#fbbf24'}40`}>
									In Development
								</span>
							)}
						</div>

						<!-- Browser preview -->
						{project.liveUrl && (
						<div class="w-full max-w-sm mx-auto rounded-lg overflow-hidden border border-white/10 shadow-xl" style={`box-shadow: 0 0 30px ${project.theme?.accent ?? '#818cf8'}25`}>
							<div class="flex items-center gap-2 px-3 py-2 bg-black/60 border-b border-white/10">
								<div class="flex gap-1.5">
									<div class="w-2.5 h-2.5 rounded-full bg-red-500/70"></div>
									<div class="w-2.5 h-2.5 rounded-full bg-yellow-500/70"></div>
									<div class="w-2.5 h-2.5 rounded-full bg-green-500/70"></div>
								</div>
								<div class="flex-1 mx-2 bg-white/10 rounded px-2 py-0.5 text-xs text-gray-400 truncate">
									{project.liveUrl.replace('https://', '')}
								</div>
							</div>
							<div class="aspect-video bg-gray-900">
								<img
									src={`https://s0.wordpress.com/mshots/v1/${encodeURIComponent(project.liveUrl)}?w=900&h=506`}
									alt={`${project.title} preview`}
									class="w-full h-full object-contain"
									/>
								</div>
							</div>
						)}

						<!-- Description -->
						<p class="text-base md:text-lg text-gray-300 max-w-xl">
							{project.description}
						</p>

						<!-- Tags + buttons -->
						<div class="flex flex-wrap gap-2 justify-center">
							{project.tags.map(tag => (
								<span class="bg-white/10 text-white px-3 py-1 rounded-full text-sm" style={`border: 1px solid ${project.theme?.accent ?? '#ffffff'}40`}>
									{tag}
								</span>
							))}
						</div>
						<div class="flex gap-3">
							{project.liveUrl && (
								<a
									href={project.liveUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="group px-5 py-2.5 rounded-lg font-semibold text-sm transition hover:scale-105 flex items-center gap-2"
									style={`background: ${project.theme?.accent ?? '#ffffff'}; color: #000`}
								>
									View Project
									<svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
									</svg>
								</a>
							)}
							{project.githubUrl && (
								<a
									href={project.githubUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="bg-white/10 text-white px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-white/20 transition border border-white/20"
								>
									View Code
								</a>
							)}
						</div>

						<!-- Collaborators -->
						{project.collaborators && project.collaborators.length > 0 && (
							<div class="text-gray-500 text-xs">
								<span class="uppercase tracking-widest mr-2">With:</span>
								{project.collaborators.map(collab => (
									<a
										href={collab.url}
										target="_blank"
										rel="noopener noreferrer"
										class="text-white hover:text-indigo-400 transition underline mr-2"
									>
										{collab.name}
									</a>
								))}
							</div>
						)}

					</div>
				</div>
			</div>
			))}
		</div>
	</div>
	
	<!-- Navigation arrows -->
	<button 
		class="nav-btn prev absolute left-4 md:left-8 top-1/2 -translate-y-1/2 z-10 bg-white/10 backdrop-blur-sm hover:bg-white/20 text-white p-4 rounded-full transition border border-white/20"
		aria-label="Previous project"
	>
		<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
		</svg>
	</button>
	<button 
		class="nav-btn next absolute right-4 md:right-8 top-1/2 -translate-y-1/2 z-10 bg-white/10 backdrop-blur-sm hover:bg-white/20 text-white p-4 rounded-full transition border border-white/20"
		aria-label="Next project"
	>
		<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
		</svg>
	</button>
	
	<!-- Slide indicators -->
	<div class="absolute bottom-4 left-1/2 -translate-x-1/2 z-10 flex gap-3">
		<button
			class="indicator w-3 h-3 rounded-full bg-white/30 hover:bg-white/50 transition"
			data-slide="0"
			aria-label="Go to slide 1"
		></button>
		{projects.map((_, index) => (
			<button 
				class="indicator w-3 h-3 rounded-full bg-white/30 hover:bg-white/50 transition"
				data-slide={index + 1}
				aria-label={`Go to slide ${index + 2}`}
			></button>
		))}
	</div>

	<!-- Project counter -->
	<div class="absolute bottom-16 right-8 text-white text-lg font-medium">
		<span class="current-slide">1</span> / <span>{projects.length + 1}</span>
	</div>
</div>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const slider = document.querySelector('.slider') as HTMLElement;
		const slides = document.querySelectorAll('.slide');
		const prevBtn = document.querySelector('.nav-btn.prev') as HTMLButtonElement;
		const nextBtn = document.querySelector('.nav-btn.next') as HTMLButtonElement;
		const indicators = document.querySelectorAll('.indicator');
		const currentSlideEl = document.querySelector('.current-slide') as HTMLElement;
		
		let currentIndex = 0;
		const totalSlides = slides.length;
		
		function updateSlider() {
			slider.style.transform = `translateX(-${currentIndex * 100}%)`;
			
			// Update indicators
			indicators.forEach((indicator, index) => {
				if (index === currentIndex) {
					indicator.classList.add('!bg-white');
				} else {
					indicator.classList.remove('!bg-white');
				}
			});
			
			// Update counter
			currentSlideEl.textContent = (currentIndex + 1).toString();
		}
		
		function nextSlide() {
			currentIndex = (currentIndex + 1) % totalSlides;
			updateSlider();
		}
		
		function prevSlide() {
			currentIndex = (currentIndex - 1 + totalSlides) % totalSlides;
			updateSlider();
		}
		
		function goToSlide(index: number) {
			currentIndex = index;
			updateSlider();
		}
		
		// PFS hero CTA
		document.getElementById('pfs-view-work')?.addEventListener('click', () => goToSlide(1));

		// Navigation buttons
		prevBtn?.addEventListener('click', prevSlide);
		nextBtn?.addEventListener('click', nextSlide);
		
		// Indicators
		indicators.forEach((indicator, index) => {
			indicator.addEventListener('click', () => goToSlide(index));
		});
		
		// Keyboard navigation
		document.addEventListener('keydown', (e) => {
			if (e.key === 'ArrowLeft') prevSlide();
			if (e.key === 'ArrowRight') nextSlide();
		});
		
		// Touch/swipe support
		let touchStartX = 0;
		let touchEndX = 0;
		
		slider?.addEventListener('touchstart', (e) => {
			touchStartX = e.changedTouches[0].screenX;
		});
		
		slider?.addEventListener('touchend', (e) => {
			touchEndX = e.changedTouches[0].screenX;
			handleSwipe();
		});
		
		function handleSwipe() {
			if (touchEndX < touchStartX - 50) nextSlide();
			if (touchEndX > touchStartX + 50) prevSlide();
		}
		
		// Initialize
		updateSlider();
	});
</script>

<style>
	@keyframes fade-in {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
	
	.animate-fade-in {
		animation: fade-in 0.8s ease-out;
	}
</style>
